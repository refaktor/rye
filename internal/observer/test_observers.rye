; Variable Observer Tests
print "## Observer Tests"

; Basic observer functionality
assert\display "basic observer" {
	x5: var 'counter5 0
	var 'last-seen5 0
	on-change x5 { last-seen5:: counter5 }
	counter5:: 5
	counter5:: 10
	last-seen5
} 10

; Multiple observers on same variable
assert\display "multiple observers" {
	var 'obs6a-count 0
	var 'obs6b-count 0
	y6: var 'temperature6 20
	on-change y6 { inc! 'obs6a-count }
	on-change y6 { inc! 'obs6b-count }
	temperature6:: 30
	temperature6:: 15
	obs6a-count + obs6b-count
} 4

; Context isolation - observers in different contexts
assert\display "context isolated observers" {
	ctx7a: context {
		w: var 'value 1
		var 'triggered false
		on-change w { triggered:: true }
	}
	ctx7b: context {
		w: var 'value 100
		var 'triggered false
		on-change w { triggered:: true }
	}
	; Modify ctx7a value
	ctx7a/value:: 42
	; ctx7b should not be affected
	ctx7b/triggered
} false

assert\display "context1 observer triggers" {
	ctx8: context {
		w: var 'value 1
		var 'triggered false
		on-change w { triggered:: true }
	}
	ctx8/value:: 42
	ctx8/triggered
} true

; Observer with conditional logic
assert\display "observer with conditional" {
	var 'high-temp-alert9 false
	y9: var 'temperature9 20
	on-change y9 { 
		if temperature9 > 25 { high-temp-alert9:: true }
	}
	temperature9:: 30
	high-temp-alert9
} true

assert\display "observer conditional not triggered" {
	var 'high-temp-alert10 false
	y10: var 'temperature10 20
	on-change y10 { 
		if temperature10 > 25 { high-temp-alert10:: true }
	}
	temperature10:: 20
	high-temp-alert10
} false

print ""
