section "Conversion " "Functions for converting between different types and kinds" {
	group "convert" 
	"Converts value from one kind to another based on a conversion specification block."
	{
		argsn 2
		arg `value: Dict or RyeCtx to convert`
		arg `spec: Block specifying the conversion rules`
		returns `converted value based on the specification`
	}

	{
		; TODO: convert returns different type than expected - needs investigation
		; equal { dict { "first-name" "John" } |convert { name: .first-name } |type? } 'ctx
	}

	{
	}

	group "converter" 
	"Registers a converter between two kinds of objects."
	{
		argsn 3
		argtypes {
			1 [ Kind ]
			2 [ Kind Block ]
			3 [ Block ]
		}
		arg `source-kind: Kind to convert from`
		arg `target-kind: Kind to convert to`
		arg `spec: Block specifying conversion rules`
		returns `the target kind with the converter registered`
	}

	{
		; TODO: converter test needs proper setup - needs investigation
		; equal { converter 'source-kind 'target-kind { name: .full-name } |type? } 'kind
	}

	{
	}

}

