section "Constructors " "Functions that construct a table." {
	group "table" 
	"Creates a table by accepting block of column names and flat block of values"
	{
		argsn 2
		argtypes {
			1 [ Block ]
			2 [ Block ]
		}
		arg `columns`
		arg `data`
	}

	{
		equal { table { "a" } { 1 2 } |type? } 'table
		equal { table { 'a  } { 1 2 } |type? } 'table
		equal { table { 'a 'b } { 1 2 3 4 } |length? } 2
	}

	{
	}

	group "table\\columns" 
	"Creats a table by accepting a block of columns"
	{
		argsn 2
		arg `columns - names of the columns`
		arg `data - block or list of columns (each column is a block or list)`
	}

	{
		equal { table\columns { "a" } { { 1 2 3 } } |type? } 'table
		equal { table\columns { "a" "b" } { { 1 2 3 } { 4 5 6 } } |length? } 3
	}

	{
`table\columns { 'a 'b } { { 1 2 } { "x" "y" } }
`	}

	group "table\\rows" 
	"Creates a table by accepting a block or list of rows"
	{
		argsn 2
		argtypes {
			2 [ Block List ]
		}
		arg `columns - names of the columns`
		arg `data - block or list of rows (each row is a block or list)`
	}

	{
		equal { table\rows { 'a 'b } { { 1 2 } { 3 4 } } } table { 'a 'b } { 1 2 3 4 }
		equal { table\rows { 'a 'b } list [ list [ 1 2 ] list [ 3 4 ] ] |type? } 'table
	}

	{
	}

	group "to-table" 
	"Creates a table by accepting block or list of dicts"
	{
		argsn 1
		argtypes {
			1 [ Block List ]
		}
		arg `data`
	}

	{
		equal { to-table list [ dict { "a" 1 } dict { "a" 2 } ] |type? } 'table
		equal { to-table list [ dict { "a" 1 "b" "Jim" } dict { "a" 2 "b" "Bob" } ] |header? |sort } list { "a" "b" }
		equal { to-table list [ dict { "a" 1 "b" "Jim" } dict { "a" 2 "b" "Bob" } ] |column? "b" |first } "Jim"
	}

	{
	}

}

section "Filtering " "Functions that construct a table." {
	group "where-equal" 
	"Returns table of rows where specific colum is equal to given value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `value`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 2 3 2 } |where-equal "a" 2 |length? } 2
	}

	{
	}

	group "where-not-equal" 
	"Returns table of rows where specific colum is not equal to given value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `value`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 2 3 2 } |where-not-equal "a" 2 |length? } 2
	}

	{
	}

	group "where-void" 
	"Returns table of rows where specific colum is void."
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 _ 3 _ } |where-void "a" |length? } 2
	}

	{
	}

	group "where-match" 
	"Returns table of rows where a specific colum matches a regex."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Native Word String ]
			3 [ Native ]
		}
		arg `sheet`
		arg `column`
		arg `regexp`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { "1" "2" "a3" "2b" } |where-match 'a regexp "^[0-9]$" |length? } 2
	}

	{
	}

	group "where-contains" 
	"Returns table of rows where specific colum contains a given string value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
			3 [ String ]
		}
		arg `sheet`
		arg `column`
		arg `substring`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { "1" "2" "a3" "2b" } |where-contains 'a "2" |length? } 2
	}

	{
`sheet: table { "name" } { "Enno" "Enya" "Enid" "Bob" "Bill" "Benn" }
sheet .where-contains 'name "nn"
`	}

	group "where-not-contains" 
	"Returns table of rows where specific colum does not contain a given string value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
			3 [ String ]
		}
		arg `sheet`
		arg `column`
		arg `substring`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { "1" "2" "a3" "2b" } |where-not-contains 'a "3" |length? } 3
	}

	{
`sheet: table { "name" } { "Enno" "Enya" "Enid" "Bob" "Bill" "Benn" }
sheet .where-not-contains 'name "nn"
`	}

	group "where-greater" 
	"Returns table of rows where specific colum is greater than given value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `value`
		arg `Tags: #filter #table`
	}

	{
		equal { table { 'a } { 1 2 3 2 } |where-greater 'a 1 |length? } 3
	}

	{
`sheet: table { "name" "age" } { "Enno" 30 "Enya" 25 "Enid" 40 "Bob" 19 "Bill" 45 "Benn" 29 }
sheet .where-greater 'age 29
`	}

	group "where-lesser" 
	"Returns table of rows where specific colum is lesser than given value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `value`
		arg `Tags: #filter #table`
	}

	{
		equal { table { 'a } { 1 2 3 2 } |where-lesser 'a 3 |length? } 3
	}

	{
	}

	group "where-between" 
	"Returns table of rows where specific colum is between given values."
	{
		argsn 4
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `lower-limit`
		arg `upper-limit`
		arg `Tags: #filter #table`
	}

	{
		equal { table { 'a } { 1 2 3 2 } |where-between 'a 1 3 |length? } 2
	}

	{
	}

	group "where-between\\inclusive" 
	"Returns table of rows where specific colum is between given values (inclusive)."
	{
		argsn 4
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `sheet`
		arg `column`
		arg `lower-limit`
		arg `upper-limit`
		arg `Tags: #filter #table`
	}

	{
		equal { table { 'a } { 1 2 3 2 5 } |where-between\inclusive 'a 2 3 |length? } 3
	}

	{
	}

	group "where-in" 
	"Returns table of rows where specific colum value is found in block of values."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
			3 [ Block ]
		}
		arg `sheet`
		arg `column`
		arg `values-filtered-for`
		arg `Tags: #filter #table`
	}

	{
		equal { table { "name" "age" } { "Enno" 30 "Enya" 25 "Bob" 19 }
		|where-in 'name { "Enno" "Enya" "Roger" } |column? "age"
		} { 30 25 }
	}

	{
	}

	group "where-not-in" 
	"Returns table of rows where specific colum value is not found in block of values."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
			3 [ Block ]
		}
		arg `sheet`
		arg `column`
		arg `values-filtered-for`
		arg `Tags: #filter #table`
	}

	{
		equal { table { "name" "age" } { "Enno" 30 "Enya" 25 "Bob" 19 }
		|where-not-in 'name { "Enno" "Enya" "Roger" } |column? "age"
		} { 19 }
	}

	{
	}

	group "where" 
	"Returns table of rows where code block evaluates to true for the column value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String Block ]
			3 [ Block Builtin Function ]
		}
		arg `table`
		arg `column - column name (word or string) or block of column names`
		arg `code - block that receives column value (or has columns as words) and returns truthy/falsy`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 2 3 4 } |where 'a { > 2 } |length? } 2
		equal { table { 'a } { 1 2 3 4 } |where 'a { .is-even } |length? } 2
		equal { table { 'name 'age } { "Jim" 30 "Jane" 25 } |where 'age { > 26 } |column? 'name } { "Jim" }
		equal { table { 'a 'b } { 1 10 2 20 3 30 } |where { 'a 'b } { ( a + b ) > 25 } |length? } 1
		equal { table { 'a 'b } { 1 10 2 20 3 30 } |where { 'a 'b } { all { a > 1 b > 15 } } |length? } 2
	}

	{
`table { "name" "age" } { "Jim" 30 "Jane" 25 "Bob" 35 } |where 'age { > 26 }
table { "a" "b" } { 1 10 2 20 3 30 } |where { 'a 'b } { ( a + b ) > 25 }
`	}

	group "distinct" 
	"Returns table with duplicate rows removed based on specified column(s)."
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Word String Block ]
		}
		arg `table`
		arg `column - column name (word or string) or block of column names`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 2 1 3 2 } |distinct 'a |length? } 3
		equal { table { 'a 'b } { 1 10 1 10 1 20 } |distinct { 'a 'b } |length? } 2
	}

	{
`table { "name" "age" } { "Jim" 30 "Jane" 25 "Jim" 30 } |distinct 'name
table { "a" "b" } { 1 10 1 20 2 10 } |distinct { 'a 'b }
`	}

	group "fill-void" 
	"Returns table with void values in specified column replaced with given value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
		arg `table`
		arg `column - column name (word or string)`
		arg `value - value to replace void with`
		arg `Tags: #transform #tables`
	}

	{
		equal { table { 'a } { 1 _ 3 _ } |fill-void 'a 0 |column? 'a } { 1 0 3 0 }
		equal { table { 'a } { 1 _ 3 _ } |fill-void 'a 99 |column? 'a |sum } 202
	}

	{
`table { "name" "age" } { "Jim" 30 "Jane" _ } |fill-void 'age 0
`	}

	group "count-where" 
	"Returns count of rows where code block evaluates to true for the column value."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String Block ]
			3 [ Block Builtin Function ]
		}
		arg `table`
		arg `column - column name (word or string) or block of column names`
		arg `code - block that receives column value and returns truthy/falsy`
		arg `Tags: #filter #tables`
	}

	{
		equal { table { 'a } { 1 2 3 4 } |count-where 'a { > 2 } } 2
		equal { table { 'a } { 1 2 3 4 } |count-where 'a { .is-even } } 2
		equal { table { 'a 'b } { 1 10 2 20 3 30 } |count-where { 'a 'b } { ( a + b ) > 25 } } 1
	}

	{
`table { "name" "age" } { "Jim" 30 "Jane" 25 "Bob" 35 } |count-where 'age { > 26 }
`	}

}

section "Row level functions " "Functions that construct a table." {
	group "add-row" 
	"Returns a table with new-row added to it"
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Block List ]
		}
		arg `sheet`
		arg `new-row`
	}

	{
		equal {
		table { "a" "b" } { 6 60 7 70 } |add-row { 8 80 } |-> 2 |-> "b"
		} 80
	}

	{
	}

	group "get-rows" 
	"Get rows as a native. This value can be used in `add-rows` and `add-rows!`"
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
		arg `sheet`
	}

	{
		equal {
		table { "a" "b" } { 6 60 7 70 } |get-rows |type?
		} 'native
	}

	{
	}

	group "add-rows" 
	"Add one or more rows to a table"
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Block Native ]
		}
		arg `sheet - the sheet that is getting rows added to it`
		arg `rows - a block containing one or more rows worth of values, or a TableRow Native value`
	}

	{
		equal {
		ref table { "a" "b" } { 6 60 7 70 } :sheet
		sheet .deref |add-rows [ 3 30 ] |length?
		} 3
		equal {
		ref table { "a" "b" } { 1 80 2 90 } :sheet
		sheet .deref |add-rows { 3 30 } |length?
		} 3
	}

	{
	}

	group "add-rows!" 
	"Add one or more rows to a table ref"
	{
		argsn 2
		argtypes {
			1 [ Table PersistentTable ]
			2 [ Block Native ]
		}
		arg `sheet - the reference to the sheet that is getting rows added to it`
		arg `rows - a block containing one or more rows worth of values, or a TableRow Native value`
		arg `Tags: #spreasheet #mutation`
	}

	{
		equal {
		ref table { "a" "b"  } { 1 10 2 20 } :sheet
		sheet .add-rows! [ 3 30 ] sheet .deref .length?
		} 3
	}

	{
	}

	group "update-row!" 
	"Update the row at the given index."
	{
		argsn 3
		argtypes {
			2 [ Integer ]
			3 [ Function Dict TableRow ]
		}
		arg `sheet-ref - A ref to a table`
		arg `idx - the index of the row to update, 1-based`
		arg `updater - One of either a function, a dict, or a Table Row`
		arg `Tags: #table #mutation`
	}

	{
		equal {
		spr1: ref table { "a" "b" } { 1 10 2 20 }
		spr1 .update-row! 1 dict [ "a" 111 ]
		spr1 .deref .A1
		} 111
		equal {
		spr1: ref table { "a" "b" } { 1 10 2 20 }
		incrA: fn { row } { row ++ [ "a" ( "a" <- row ) + 9 ] }
		update-row! spr1 1 ?incrA
		spr1 |deref |A1
		} 10
	}

	{
	}

	group "remove-row!" 
	"Remove a row from a table by index"
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Block Native ]
		}
		arg `sheet-ref`
		arg `row-idx - Index of row to remove, 1-based`
		arg `Tags: #table #mutation`
	}

	{
		equal {
		spr1: ref table { "a" "b" } { 1 10 2 20 }
		spr1 .remove-row! 1
		spr1 .deref .A1
		} 2
	}

	{
	}

}

section "Column level functions " "Functions that construct a table." {
	group "columns?" 
	"Returns table with just given columns. Use lsetwords (:newName) to rename the previous column."
	{
		argsn 2
		argtypes {
			1 [ Block Table ]
		}
	}

	{
		equal { table { "name" "age" "job_title" } { "Bob" 25 "Janitor" "Alice" 29 }
		|columns? { 'name 'age } |header? } list { "name" "age" }
	}

	{
	}

	group "header?" 
	"Gets the column names (header) as block."
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
	}

	{
		equal { table { "age" "name" } { 123 "Jim" 29 "Anne" }
		|header? } list { "age" "name" }
	}

	{
	}

	group "column?" 
	"Gets all values of a column as a block."
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Word String ]
		}
	}

	{
		equal { table { "name" "age" "job_title" } { "Bob" 25 "Janitor" "Alice" 29 "Teacher" }
		|column? 'name }  { "Bob" "Alice" }
	}

	{
	}

	group "drop-column" 
	"Remove a column from a table. Returns new table"
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Word String Block ]
		}
	}

	{
		equal { table { "name" "age" "job_title" } { "Bob" 25 "Janitor" "Alice" 29 "Librarian" }
		|drop-column "name" |header? } list { "age" "job_title" }
	}

	{
	}

	group "rename-column!" 
	"Remove a column from a table. Returns new table"
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word Block ]
		}
	}

	{
		equal { tab: ref table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19 }
		tab .rename-column! "name" "first_name" , tab .header? } list { "first_name" "age" }
	}

	{
	}

	group "gen-column" 
	"Adds a new column to table. Changes in-place and returns the new table."
	{
		argsn 4
		argtypes {
			1 [ Table ]
			2 [ Word ]
			3 [ Block ]
			4 [ Block ]
		}
	}

	{
		equal { table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19 }
		|gen-column 'job { } { "Cook" } |column? "job" } { "Cook" "Cook" "Cook" }
		equal { table { "email" } { "john@example.com" "jane@test.org" }
		|gen-column 'domain 'email [ regexp ".*@(.+)$" "$1" ] |column? "domain" } { "example.com" "test.org" }
	}

	{
	}

	group "update-column!" 
	"Updates all cells in a column by applying a function that receives the cell value and the row."
	{
		argsn 3
		argtypes {
			2 [ Word String ]
			3 [ Function ]
		}
		arg `table-ref - a reference to the table to update`
		arg `column-name - name of the column to update (word or string)`
		arg `fn - function that accepts (cell, row) and returns the new cell value`
		arg `Tags: #table #column #mutation`
	}

	{
		equal { ref table { "a" "b" } { 1 10 2 20 } :tab , tab .update-column! "a" fn { c r } { c + 100 } , tab .deref .column? "a" } { 101 102 }
		equal { ref table { "a" "b" } { 1 10 2 20 } :tab , tab .update-column! "a" fn { c r } { r -> "b" } , tab .deref .column? "a" } { 10 20 }
	}

	{
	}

	group "add-column" 
	"Adds a new column to table with the given data. Returns the modified table."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String ]
			3 [ Block List ]
		}
		arg `table - the table to add a column to`
		arg `column-name - name of the new column (word or string)`
		arg `data - block or list containing values for the new column (must match number of rows)`
		arg `Tags: #table #column`
	}

	{
		equal { table { "a" "b" } { 1 10 2 20 3 30 } |add-column 'c { 100 200 300 } |column? "c" } { 100 200 300 }
		equal { table { "a" } { 1 2 3 } |add-column 'b list [ "x" "y" "z" ] |column? "b" } { "x" "y" "z" }
	}

	{
	}

}

section "Miscelaneous " "" {
	group "order-by!" 
	"Sorts row by given column, changes table in place."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word ]
			3 [ Word ]
		}
	}

	{
		equal { tab: table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19  }
		tab .order-by! 'age 'asc |column? "age" } { 19 25 29 }
	}

	{
	}

	group "order-by" 
	"Sorts row by given column, changes table in place."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word ]
			3 [ Word ]
		}
	}

	{
		equal { tab: table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19  }
		|order-by 'age 'desc |column? "age" } { 29 25 19 }
	}

	{
	}

	group "add-indexes!" 
	"Creates an index for all values in the provided columns. Changes in-place and returns the new table."
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Block ]
		}
	}

	{
		equal { table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19 }
		|add-indexes! { name } |indexes? } { "name" }
	}

	{
	}

	group "indexes?" 
	"Returns the columns that are indexed in a table."
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
	}

	{
		equal { table { "name" "age" } { "Bob" 25 "Alice" 29 "Charlie" 19 }
		|add-indexes! { name age } |indexes? |length? } 2
	}

	{
	}

	group "autotype" 
	"Takes a table and tries to determine and change the types of columns."
	{
		argsn 2
		argtypes {
			1 [ Table ]
			2 [ Decimal ]
		}
	}

	{
		equal { table { "age" } { 123 29 19 }
		|autotype 1.0 |types? } { integer }
	}

	{
	}

	group "left-join" 
	"Left joins two tables on the given columns."
	{
		argsn 4
		argtypes {
			1 [ Table ]
			2 [ Table ]
			3 [ Word String ]
			4 [ Word String ]
		}
	}

	{
		equal {
		names: table { "id" "name" } { 1 "Paul" 2 "Chani" 3 "Vladimir" } ,
		houses: table { "id" "house" } { 1 "Atreides" 3 "Harkonnen" } ,
		
		names .inner-join houses 'id 'id |header?
		} list { "id" "name" "id_2" "house" }
		equal {
		names: table { "id" "name" } { 1 "Paul" 2 "Chani" 3 "Vladimir" } ,
		houses: table { "id" "house" } { 1 "Atreides" 3 "Harkonnen" } ,
		
		names .left-join houses 'id 'id |column? "name"
		} { "Paul" "Chani" "Vladimir" }
	}

	{
	}

	group "inner-join" 
	"Inner joins two tables on the given columns."
	{
		argsn 4
		argtypes {
			1 [ Table ]
			2 [ Table ]
			3 [ Word String ]
			4 [ Word String ]
		}
	}

	{
		equal {
		names: table { "id" "name" } { 1 "Paul" 2 "Chani" 3 "Vladimir" } ,
		houses: table { "id" "house" } { 1 "Atreides" 3 "Harkonnen" } ,
		
		names .inner-join houses 'id 'id |header?
		} list { "id" "name" "id_2" "house" }
		equal {
		names: table { "id" "name" } { 1 "Paul" 2 "Chani" 3 "Vladimir" } ,
		houses: table { "id" "house" } { 1 "Atreides" 3 "Harkonnen" } ,
		
		names .inner-join houses 'id 'id |column? "name"
		} {  "Paul" "Vladimir" }
	}

	{
	}

	group "group-by" 
	"Groups a table by the given column(s) and (optional) aggregations."
	{
		argsn 3
		argtypes {
			1 [ Table ]
			2 [ Word String Block ]
			3 [ Block ]
		}
	}

	{
		equal {
		table { "name" "val" } { "a" 1 "b" 6 "a" 5 "b" 10 "a" 7 }
		|group-by 'name { 'name count 'val sum } |column? "val_sum" |sort
		} { 13.0 16.0 }
		equal {
		table { "name" "val" } { "a" 1 "b" 6 "a" 5 "b" 10 "a" 7 }
		|group-by 'name { 'name count 'val min } |column? "val_min" |sort
		} { 1.0 6.0 }
		equal {
		table { "name" "val" } { "a" 1 "b" 6 "a" 5 "b" 10 "a" 12 }
		|group-by 'name { 'name count 'val avg } |column? "val_avg" |sort
		} { 6.0 8.0 }
	}

	{
	}

	group "A1" 
	"Accepts a Table and returns the first row first column cell."
	{
		argsn 1
	}

	{
		equal { table { 'a } { 123 234 345 } |A1 } 123
	}

	{
	}

	group "B1" 
	"Accepts a Table and returns the first row second column cell."
	{
		argsn 1
	}

	{
		equal { table { 'a 'b } { 123 234 345 456 } |B1 } 234
	}

	{
	}

	group "A2" 
	"Accepts a Table and returns the second row first column cell."
	{
		argsn 1
	}

	{
		equal { table { 'a 'b } { 123 234 345 456 } |A2 } 345
	}

	{
	}

	group "B2" 
	"Accepts a Table and returns the second row second column cell."
	{
		argsn 1
	}

	{
		equal { table { 'a 'b } { 123 234 345 456 } |B2 } 456
	}

	{
	}

}

section "Loading and saving " "Functions that construct a table." {
	group "file-uri//Load\\csv" 
	"Loads a .csv file to a table datatype."
	{
		argsn 1
		argtypes {
			1 [ Uri ]
		}
		arg `file-uri - location of csv file to load`
		arg `Tags: #table #loading #csv`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.csv"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
spr1 .Save\csv* f
spr2:: Load\csv f |autotype 1.0
spr1 = spr2
} true
`	}

}

section "Loading and saving " "Functions that construct a table." {
	group "file-uri//Load\\csv\\" 
	"Loads a .csv file to a table datatype."
	{
		argsn 2
		argtypes {
			1 [ Uri ]
			2 [ String ]
		}
		arg `file-uri - location of csv file to load`
		arg `Tags: #table #loading #csv`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.csv"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
spr1 .Save\csv* f
spr2:: Load\csv f |autotype 1.0
spr1 = spr2
} true
`	}

	group "file-uri//Load\\tsv" 
	"Loads a .csv file to a table datatype."
	{
		argsn 1
		argtypes {
			1 [ Uri ]
		}
		arg `file-uri - location of csv file to load`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.tsv"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
spr1 .Save\tsv* f
spr2:: Load\tsv f |autotype 1.0
spr1 = spr2
} true
`	}

	group "file-uri//Save\\csv" 
	"Saves a table to a .csv file."
	{
		argsn 2
		argtypes {
			1 [ Uri ]
			2 [ Table ]
		}
		arg `file-uri - where to save the sheet as a .csv file`
		arg `table    - the table to save`
		arg `Tags: #table #saving #csv`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.csv"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
f .Save\csv spr1
spr2:: Load\csv f |autotype 1.0
spr1 = spr2
} true
`	}

	group "file-uri//Save\\tsv" 
	"Saves a table to a .tsv file."
	{
		argsn 2
		argtypes {
			1 [ Uri ]
			2 [ Table ]
		}
		arg `file-uri - where to save the sheet as a .tsv file`
		arg `table    - the table to save`
		arg `Tags: #table #saving #tsv`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.tsv"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
f .Save\tsv spr1
spr2:: Load\tsv f |autotype 1.0
spr1 = spr2
} true
`	}

	group "file-uri//Load\\xlsx" 
	"Loads the first sheet in an .xlsx file to a Table."
	{
		argsn 1
		argtypes {
			1 [ Uri ]
		}
		arg `file-uri - location of xlsx file to load`
		arg `Tags: #table #loading #xlsx`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.xlsx"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
spr1 .Save\xlsx* f
spr2:: Load\xlsx f |autotype 1.0
spr1 = spr2
} true
`	}

	group "file-uri//Save\\xlsx" 
	"Saves a Table to a .xlsx file."
	{
		argsn 2
		argtypes {
			1 [ Uri ]
			2 [ Table ]
		}
		arg `file-uri - where to save the table as a .xlsx file`
		arg `table    - the table to save`
		arg `Tags: #table #saving #xlsx`
	}

	{
	}

	{
`equal {
cc os
f:: mktmp ++ "/test.xlsx"
spr1:: table { "a" "b" "c" } { 1 1.1 "a" 2 2.2 "b" 3 3.3 "c" }
f .Save\xlsx spr1
spr2:: Load\xlsx f |autotype 1.0
spr1 = spr2
} true
`	}

	group "persistent-table" 
	"Creates a persistent table using BadgerDB for storage"
	{
		argsn 3
		argtypes {
			2 [ String ]
			3 [ String ]
		}
		arg `columns - block of column names`
		arg `db-path - path to BadgerDB database`
		arg `table-name - name of the table`
	}

	{
		; equal { persistent-table { "a" "b" } "/tmp/test_db" "test_table" |type? } 'persistent-table
	}

	{
	}

	group "close-persistent-table!" 
	"Closes the BadgerDB connection for a persistent table"
	{
		argsn 1
		argtypes {
			1 [ PersistentTable ]
		}
		arg `persistent-table - the persistent table to close`
	}

	{
		; equal { pt: persistent-table { "a" "b" } "/tmp/test_db" "test_table"
		;        pt .close-persistent-table! |type? } 'persistent-table
	}

	{
	}

	group "parse\\csv" 
	"Parses a CSV string to a table datatype."
	{
		argsn 1
		argtypes {
			1 [ String ]
		}
		arg `csv-string - string containing CSV data`
		arg `Tags: #table #parsing #csv`
	}

	{
		equal { `a,b\n1,2\n3,4` |parse\csv |length? } 2
		equal { `a,b\n1,2\n3,4` |parse\csv |column? "a" } { "1" "3" }
	}

	{
	}

	group "parse\\csv\\" 
	"Parses a CSV string to a table datatype with custom separator."
	{
		argsn 2
		argtypes {
			1 [ String ]
			2 [ String ]
		}
		arg `csv-string - string containing CSV data`
		arg `separator - single character separator`
		arg `Tags: #table #parsing #csv`
	}

	{
		equal { `a,b\n1,2\n3,4` |parse\csv\ "," |length? } 2
		equal { `a;b\n1;2\n3;4` |parse\csv\ ";" |column? "a" } { "1" "3" }
	}

	{
	}

	group "parse\\tsv" 
	"Parses a TSV (tab-separated values) string to a table datatype."
	{
		argsn 1
		argtypes {
			1 [ String ]
		}
		arg `tsv-string - string containing TSV (tab-separated values) data`
		arg `Tags: #table #parsing #tsv`
	}

	{
		equal { `a	b\n1	2\n3	4` |parse\tsv |length? } 2
		equal { `a	b\n1	2\n3	4` |parse\tsv |column? "a" } { "1" "3" }
	}

	{
	}

	group "format\\csv" 
	"Converts a table to a CSV string."
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
		arg `table - the table to convert to CSV string`
		arg `Tags: #table #formatting #csv`
	}

	{
		equal { table { "a" "b" } { 1 2 3 4 } |format\csv } "a,b\n1,3\n2,4\n"
		equal { table { "name" "age" } { "Jim" 30 "Jane" 25 } |format\csv |split "\n" |length? } 4
	}

	{
	}

	group "format\\tsv" 
	"Converts a table to a TSV string."
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
		arg `table - the table to convert to TSV string`
		arg `Tags: #table #formatting #tsv`
	}

	{
	}

	{
`equal { table { "a" "b" } { 1 2 3 4 } |format\tsv } "a\tb\n1\t3\n2\t4\n"
equal { table { "name" "age" } { "Jim" 30 "Jane" 25 } |format\tsv |split "\n" |length? } 4
`	}

	group "parse\\xlsx" 
	"Parses an xlsx binary string or bytes into a table (first sheet)."
	{
		argsn 1
		argtypes {
			1 [ String Bytes ]
		}
		arg `data - the string with xlsx binary data or bytes native value`
		arg `Tags: #table #parsing #xlsx`
	}

	{
	}

	{
	}

	group "format\\xlsx" 
	"Converts a table to an XLSX as bytes native value."
	{
		argsn 1
		argtypes {
			1 [ Table ]
		}
		arg `table - the table to convert to XLSX bytes`
		arg `Tags: #table #formatting #xlsx`
	}

	{
	}

	{
`table { "a" "b" } { 1 2 3 4 } |format\xlsx |type? ; => 'native
`	}

}

